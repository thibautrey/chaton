{
  "name": "chaton",
  "private": true,
  "version": "0.213.0",
  "description": "Electron + React + TypeScript + shadcn UI skeleton",
  "main": "dist-electron/electron/main.js",
  "type": "module",
  "scripts": {
    "postinstall": "npx electron-rebuild -f -w better-sqlite3 && node scripts/patch-model-registry.js && node scripts/patch-copilot-openai-completions.js",
    "commit": "node scripts/add-commit.js",
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run dev:desktop\"",
    "dev:renderer": "vite",
    "dev:desktop": "npm run build:electron && wait-on tcp:5173 && env -u ELECTRON_RUN_AS_NODE VITE_DEV_SERVER_URL=http://localhost:5173 ./node_modules/.bin/electron dist-electron/electron/main.js",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "tsc -b && vite build",
    "build:electron": "rm -rf dist-electron && tsc -p tsconfig.electron.json && npm run build:builtin-extension-ui && npm run copy:electron-assets",
    "build:builtin-extension-ui": "node scripts/build-builtin-extension-ui.mjs",
    "copy:electron-assets": "node scripts/copy-electron-assets.js",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview",
    "version": "node scripts/version.js",
    "version:test": "node scripts/test-version.js",
    "dist": "npm run build && electron-builder --mac dmg",
    "package:prod:dmg": "node scripts/package-prod-dmg.js",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "dist:linux": "npm run build && electron-builder --linux --publish never",
    "dev:cloud-api": "node apps/cloud-api/server.ts",
    "dev:cloud-realtime": "node apps/cloud-realtime/server.ts",
    "dev:runtime-headless": "node apps/runtime-headless/server.ts",
    "dev:cloud": "concurrently -k \"npm run dev:cloud-api\" \"npm run dev:cloud-realtime\" \"npm run dev:runtime-headless\"",
    "check:cloud": "node --check apps/cloud-api/server.ts && node --check apps/cloud-realtime/server.ts && node --check apps/runtime-headless/server.ts",
    "check:pre-push": "npm run build && npm run check:cloud",
    "secrets:cloud": "node scripts/generate-cloud-secrets.js"
  },
  "build": {
    "appId": "com.thibaut.chaton",
    "productName": "Chatons",
    "icon": "build/icons/icon",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "!dist-electron/resources/npm{,/**}",
      "package.json",
      "build/icons/**/*"
    ],
    "extraResources": [
      {
        "from": "dist-electron/resources/npm",
        "to": "npm",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icons/icon.icns",
      "target": [
        "dmg"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSLocalNetworkUsageDescription": "Chatons needs local network access to connect to self-hosted AI providers and local development services."
      },
      "type": "distribution",
      "notarize": false
    },
    "win": {
      "icon": "build/icons/icon.ico"
    },
    "dmg": {
      "artifactName": "${productName}-latest-${arch}.${ext}"
    },
    "nsis": {
      "artifactName": "${productName}Setup-latest.${ext}"
    },
    "linux": {
      "icon": "build/icons/icon.png",
      "artifactName": "${productName}-latest.${ext}"
    },
    "directories": {
      "output": "release"
    },
    "protocols": {
      "name": "Chatons",
      "schemes": [
        "chatons"
      ]
    }
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.60.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/electron": "^7.10.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "follow-redirects": "^1.15.11",
    "framer-motion": "^12.38.0",
    "i18next": "^25.8.18",
    "isomorphic-git": "^1.37.4",
    "lucide-react": "^0.577.0",
    "nodemailer": "8.0.3",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.8",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "redis": "^5.11.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^9.25.1",
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/electron": "^1.6.12",
    "@types/follow-redirects": "^1.14.4",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "7.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.25.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.4.0",
    "npm": "^11.12.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.0",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.4"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.8.0",
    "cron": "^4.4.0"
  }
}
