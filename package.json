{
  "name": "chaton",
  "private": true,
  "version": "0.133.0",
  "description": "Electron + React + TypeScript + shadcn UI skeleton",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "postinstall": "npx electron-rebuild -f -w better-sqlite3 && node scripts/patch-model-registry.js",
    "commit": "node scripts/add-commit.js",
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run dev:desktop\"",
    "dev:renderer": "vite",
    "dev:desktop": "npm run build:electron && wait-on tcp:5173 && env -u ELECTRON_RUN_AS_NODE VITE_DEV_SERVER_URL=http://localhost:5173 ./node_modules/.bin/electron dist-electron/main.js",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "tsc -b && vite build",
    "build:electron": "tsc -p tsconfig.electron.json && npm run copy:electron-assets",
    "copy:electron-assets": "node scripts/copy-electron-assets.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "version": "node scripts/version.js",
    "version:test": "node scripts/test-version.js",
    "dist": "npm run build && electron-builder --mac dmg",
    "package:prod:dmg": "node scripts/package-prod-dmg.js",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "dist:linux": "npm run build && electron-builder --linux --publish never"
  },
  "build": {
    "appId": "com.thibaut.chaton",
    "productName": "Chatons",
    "icon": "build/icons/icon",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "build/icons/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icons/icon.icns",
      "target": [
        "dmg"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "type": "distribution",
      "notarize": false
    },
    "win": {
      "icon": "build/icons/icon.ico"
    },
    "dmg": {
      "artifactName": "${productName}-latest-${arch}.${ext}"
    },
    "nsis": {
      "artifactName": "${productName}Setup-latest.${ext}"
    },
    "linux": {
      "icon": "build/icons/icon.png",
      "artifactName": "${productName}-latest.${ext}"
    },
    "directories": {
      "output": "release"
    },
    "protocols": {
      "name": "Chatons",
      "schemes": [
        "chatons"
      ]
    }
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.55.4",
    "@radix-ui/react-slot": "^1.2.3",
    "@sentry/electron": "^7.9.0",
    "@vercel/analytics": "^1.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "follow-redirects": "^1.15.11",
    "framer-motion": "^12.34.5",
    "i18next": "^25.8.13",
    "isomorphic-git": "^1.37.2",
    "lucide-react": "^0.576.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^9.39.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/electron": "^1.4.38",
    "@types/follow-redirects": "^1.14.4",
    "@types/node": "^24.11.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^40.7.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "lint-staged": "^16.3.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.6.2"
  }
}
