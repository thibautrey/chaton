34:["$","h3",null,{"id":"force-open-onboarding-shortcut","children":"Force-open onboarding shortcut"}]
35:["$","p",null,{"children":"You can force-open onboarding at any time with:"}]
36:["$","ul",null,{"children":["\n",["$","li",null,{"children":[["$","code",null,{"children":"Cmd + Shift + O"}]," (macOS)"]}],"\n",["$","li",null,{"children":[["$","code",null,{"children":"Ctrl + Shift + O"}]," (Windows/Linux)"]}],"\n"]}]
37:["$","h3",null,{"id":"step-1-provider-setup","children":"Step 1: Provider setup"}]
38:["$","p",null,{"children":"You choose a provider preset (for example OpenAI, Mistral, Ollama, LM Studio, etc.), then set:"}]
39:["$","ul",null,{"children":["\n",["$","li",null,{"children":"API type"}],"\n",["$","li",null,{"children":"Base URL"}],"\n",["$","li",null,{"children":["API key (optional for local providers when detected locally, and optional for ",["$","code",null,{"children":"Custom"}],")"]}],"\n"]}]
3a:["$","p",null,{"children":["Provider preset cards use a transparent surface (no dark card fill) to keep labels and logos easier to read on onboarding backgrounds.\nThe Mistral card displays a gold star badge to indicate it as a preferred preset.\nClicking a provider card automatically scrolls to the provider form/API key area so you can continue setup immediately.\nWhen selecting ",["$","code",null,{"children":"Custom"}],", the form stays in custom mode while you type the provider name (typing no longer exits/hides the custom fields).\nWhen saving provider settings, Chatons now auto-corrects common base URL variants in the background for OpenAI-compatible endpoints (for example ",["$","code",null,{"children":"http://host:port"}],", ",["$","code",null,{"children":"http://host:port/"}],", ",["$","code",null,{"children":"http://host:port/v1"}],", ",["$","code",null,{"children":"http://host:port/v1/"}],") and stores the first reachable one."]}]
3b:["$","h3",null,{"id":"step-2-model-scope","children":"Step 2: Model scope"}]
3c:["$","p",null,{"children":"Chatons loads models and asks which ones should be available in your everyday model picker."}]
3d:["$","h3",null,{"id":"step-3-quick-validation","children":"Step 3: Quick validation"}]
3e:["$","p",null,{"children":"Chatons runs a basic setup check before enabling the main app."}]
3f:["$","h2",null,{"id":"3-main-interface-overview","children":"3. Main Interface Overview"}]
40:["$","p",null,{"children":"The app has three main areas."}]
41:["$","h3",null,{"id":"left-sidebar","children":"Left sidebar"}]
42:["$","p",null,{"children":"Main navigation:"}]
43:["$","ul",null,{"children":["\n",["$","li",null,{"children":["$","code",null,{"children":"New thread"}]}],"\n",["$","li",null,{"children":["$","code",null,{"children":"Automations"}]}],"\n",["$","li",null,{"children":["$","code",null,{"children":"Skills"}]}],"\n",["$","li",null,{"children":["$","code",null,{"children":"Extensions"}]}],"\n",["$","li",null,{"children":["$","code",null,{"children":"Settings"}]}],"\n"]}]
44:["$","p",null,{"children":"You also get:"}]
45:["$","ul",null,{"children":["\n",["$","li",null,{"children":["a search toggle button next to the ",["$","code",null,{"children":"+"}]," action to show/hide thread search"]}],"\n",["$","li",null,{"children":"thread/project organization options"}],"\n",["$","li",null,{"children":"update and changelog cards (outside dev mode)"}],"\n"]}]
46:["$","h3",null,{"id":"main-panel","children":"Main panel"}]
47:["$","p",null,{"children":"Shows either:"}]
48:["$","ul",null,{"children":["\n",["$","li",null,{"children":"conversation timeline"}],"\n",["$","li",null,{"children":"settings panel"}],"\n",["$","li",null,{"children":"skills panel"}],"\n",["$","li",null,{"children":"extensions panel"}],"\n",["$","li",null,{"children":"an extension main view (for example Automation)"}],"\n",["$","li",null,{"children":"extension main views use the full available content width and height of the main panel rather than the narrower conversation/settings column and viewport-estimated height"}],"\n",["$","li",null,{"children":"on empty-thread states, quick action cards are aligned to the conversation column width and centered within that column (not the full window), while still staying visually above the composer area"}],"\n",["$","li",null,{"children":"quick actions and the \"Start the conversation\" empty-state banner are shown only for truly empty threads; once a first exchange exists, they are hidden"}],"\n"]}]
49:["$","h3",null,{"id":"composer-bottom","children":"Composer (bottom)"}]
4a:["$","p",null,{"children":"Used to send prompts, attach files/images, pick model, pick thinking level, and choose agent access mode.\nThe composer bar and inner composer surface use translucent backgrounds with blur so conversation content remains subtly visible behind them."}]
4b:["$","h2",null,{"id":"4-core-daily-workflows","children":"4. Core Daily Workflows"}]
4c:["$","h3",null,{"id":"create-a-global-thread","children":"Create a global thread"}]
4d:["$","p",null,{"children":["Use ",["$","code",null,{"children":"New thread"}]," in the sidebar (or the topbar ",["$","code",null,{"children":"+"}]," button)."]}]
4e:["$","h3",null,{"id":"import-a-project","children":"Import a project"}]
4f:["$","p",null,{"children":["Use ",["$","code",null,{"children":"Add project"}]," in the sidebar."]}]
50:["$","p",null,{"children":"If the folder is not already a Git repository, Chatons initializes it automatically."}]
51:["$","h3",null,{"id":"create-a-project-thread","children":"Create a project thread"}]
52:["$","p",null,{"children":"Inside a project group, click the compose icon to create a new thread linked to that project."}]
53:["$","h3",null,{"id":"delete-threads-and-projects","children":"Delete threads and projects"}]
54:["$","p",null,{"children":"Deletion uses a two-click confirmation pattern for safety."}]
55:["$","h2",null,{"id":"5-conversation-experience","children":"5. Conversation Experience"}]
56:["$","h3",null,{"id":"model-picker","children":"Model picker"}]
57:["$","p",null,{"children":"The model chip in the composer lets you:"}]
58:["$","ul",null,{"children":["\n",["$","li",null,{"children":"use scoped models by default"}],"\n",["$","li",null,{"children":["click ",["$","code",null,{"children":"more"}]," to show all models"]}],"\n",["$","li",null,{"children":"star/unstar models to add/remove them from scoped models"}],"\n"]}]
59:["$","p",null,{"children":"The same scoped-model picker behavior is now reused in onboarding and provider/model settings, so model scope toggling is consistent across setup and daily usage."}]
5a:["$","h3",null,{"id":"thinking-level","children":"Thinking level"}]
5b:["$","p",null,{"children":"If the selected model supports reasoning levels, a thinking-level chip appears."}]
5c:["$","h3",null,{"id":"agent-access-mode","children":"Agent access mode"}]
5d:["$","p",null,{"children":"You can switch per conversation:"}]
5e:["$","ul",null,{"children":["\n",["$","li",null,{"children":[["$","code",null,{"children":"secure"}],": constrained behavior"]}],"\n",["$","li",null,{"children":[["$","code",null,{"children":"open"}],": broader file/command access behavior"]}],"\n",["$","li",null,{"children":["a friendly comparison popup is shown above the ",["$","code",null,{"children":"secure"}]," / ",["$","code",null,{"children":"open"}]," buttons in the composer, with short non-technical guidance for when to use each mode"]}],"\n"]}]
5f:["$","p",null,{"children":"If you change mode on an existing thread, Chatons restarts that conversation runtime."}]
60:["$","h3",null,{"id":"sending-while-ai-is-busy","children":"Sending while AI is busy"}]
61:["$","p",null,{"children":"If the agent is already processing or still starting up, pressing send queues your message instead of dropping it.\nThis also applies while Chatons is still tracking pending runtime commands for that conversation.\nIn that state, the send button shows a queue icon (instead of text) to keep the composer compact."}]
62:["$","h3",null,{"id":"stop-current-execution","children":"Stop current execution"}]
63:["$","p",null,{"children":"A stop button appears while the agent is processing."}]
64:["$","h2",null,{"id":"6-attachments-in-composer","children":"6. Attachments in Composer"}]
65:["$","p",null,{"children":["You can add files using ",["$","code",null,{"children":"+"}]," or drag-and-drop."]}]
66:["$","p",null,{"children":"Current behavior:"}]
67:["$","ul",null,{"children":["\n",["$","li",null,{"children":"images: sent as image payloads"}],"\n",["$","li",null,{"children":"small text-like files: included as readable text"}],"\n",["$","li",null,{"children":"other/binary files: included as base64 preview text"}],"\n"]}]
68:["$","p",null,{"children":"Attachments can be removed before sending."}]
69:["$","h2",null,{"id":"7-live-change-tracking-code-workflows","children":"7. Live Change Tracking (Code Workflows)"}]
6a:["$","p",null,{"children":"When a conversation has activity and thread-scoped changes are detected, Chatons shows a modifications panel above the composer with:"}]
6b:["$","ul",null,{"children":["\n",["$","li",null,{"children":"changed files count"}],"\n",["$","li",null,{"children":"added/removed lines"}],"\n",["$","li",null,{"children":"inline per-file diffs"}],"\n",["$","li",null,{"children":"change-to-change navigation"}],"\n"]}]
6c:["$","p",null,{"children":"This gives you a continuous view of what changed during the thread."}]
6d:["$","p",null,{"children":"Chatons also records compact file-change summaries directly in the conversation timeline after tool executions. Each row shows:"}]
6e:["$","ul",null,{"children":["\n",["$","li",null,{"children":["$","code",null,{"children":"Modifié <path> +<added> -<removed>"}]}],"\n"]}]
6f:["$","p",null,{"children":"Click a timeline row to expand the inline diff for that file directly in the thread."}]
70:["$","p",null,{"children":["These timeline rows are thread-scoped deltas (changes relative to thread start baseline), so they track what changed during the current conversation rather than whole-repository totals.\nTimeline summaries are incremental: each row shows only files that changed since the previous tool execution snapshot. Pure Git state transitions that do not introduce new content changes (for example stage/commit cleanup effects) are not surfaced as new \"Modifié\" rows. To reduce false positives from concurrent work in other threads, Chatons only surfaces these timeline file-change rows when the change is associated with a recent ",["$","code",null,{"children":"edit"}]," tool execution in the same thread."]}]
71:["$","h2",null,{"id":"8-worktree-tools","children":"8. Worktree Tools"}]
72:["$","p",null,{"children":["For project threads, worktree is ",["$","strong",null,{"children":"disabled by default"}],"."]}]
73:["$","p",null,{"children":["Use the topbar worktree icon (",["$","code",null,{"children":"branch"}]," icon) to toggle it for the current thread."]}]
74:["$","p",null,{"children":"When enabled, the icon changes color (green) to indicate active worktree mode.\nClick the icon again to disable worktree for that thread."}]
75:["$","p",null,{"children":["After activation, ",["$","code",null,{"children":"Manage worktree"}]," actions are available."]}]
76:["$","p",null,{"children":"From this dialog you can:"}]
77:["$","ul",null,{"children":["\n",["$","li",null,{"children":"inspect worktree status fields"}],"\n",["$","li",null,{"children":"generate a commit message suggestion"}],"\n",["$","li",null,{"children":"commit"}],"\n",["$","li",null,{"children":"merge to main"}],"\n",["$","li",null,{"children":"push"}],"\n"]}]
78:["$","p",null,{"children":"You can also open the worktree in VS Code if VS Code is detected."}]
79:["$","h2",null,{"id":"9-automations-user-view","children":"9. Automations (User View)"}]
7a:["$","p",null,{"children":["The ",["$","code",null,{"children":"Automations"}]," sidebar entry opens a dedicated automation screen."]}]
7b:["$","p",null,{"children":"You can:"}]
7c:["$","ul",null,{"children":["\n",["$","li",null,{"children":"list automation rules"}],"\n",["$","li",null,{"children":"create a new rule in a modal"}],"\n",["$","li",null,{"children":"set trigger, action type, cooldown, and request text"}],"\n",["$","li",null,{"children":"view recent execution history"}],"\n",["$","li",null,{"children":"delete a rule by double-clicking it"}],"\n",["$","li",null,{"children":"ask the model in a thread to program an automation task when the Automation extension tools are available in that thread"}],"\n",["$","li",null,{"children":"use the Automation screen in both light and dark app themes with matching surfaces, cards, and modal styling"}],"\n"]}]
7d:["$","h2",null,{"id":"10-skills-user-view","children":"10. Skills (User View)"}]
7e:["$","p",null,{"children":["The ",["$","code",null,{"children":"Skills"}]," panel supports:"]}]
7f:["$","ul",null,{"children":["\n",["$","li",null,{"children":"listing installed skills"}],"\n",["$","li",null,{"children":"searching/filtering skills"}],"\n",["$","li",null,{"children":"installing skills from catalog"}],"\n",["$","li",null,{"children":"uninstalling installed skills"}],"\n",["$","li",null,{"children":"a redesigned premium library UI with hero summary cards, richer catalog cards, and clearer install/discovery sections aligned with the rest of Chatons visual language"}],"\n"]}]
80:["$","h2",null,{"id":"11-extensions-user-view","children":"11. Extensions (User View)"}]
81:["$","p",null,{"children":["The ",["$","code",null,{"children":"Extensions"}]," panel supports:"]}]
82:["$","ul",null,{"children":["\n",["$","li",null,{"children":"listing installed extensions"}],"\n",["$","li",null,{"children":"browsing extension catalog"}],"\n",["$","li",null,{"children":"install / enable / disable / remove actions"}],"\n",["$","li",null,{"children":"health check action"}],"\n",["$","li",null,{"children":"viewing extension logs"}],"\n",["$","li",null,{"children":"opening the user extensions folder from the app"}],"\n",["$","li",null,{"children":["builtin extensions such as ",["$","code",null,{"children":"@chaton/automation"}]," are bundled with the application and do not appear in that user folder"]}],"\n",["$","li",null,{"children":"the old builtin example and Qwen helper extensions are no longer part of the bundled codebase"}],"\n",["$","li",null,{"children":"restarting the app when needed"}],"\n",["$","li",null,{"children":"a redesigned premium management UI with summary stats, elevated cards, clearer status pills, and a more polished discovery/install flow consistent with the rest of the app"}],"\n"]}]
83:["$","h3",null,{"id":"channel-extensions","children":"Channel extensions"}]
84:["$","p",null,{"children":"Some extensions can act as external messaging bridges, for example Telegram or WhatsApp-style integrations."}]
85:["$","p",null,{"children":["Their role is to import messages received outside Chatons into Chatons conversations.\nCurrent product rule: these imported messages are handled as ",["$","strong",null,{"children":"global threads"}]," only, not project threads."]}]
86:["$","p",null,{"children":["If at least one Channel extension is installed and enabled, Chatons shows a dedicated ",["$","code",null,{"children":"Channels"}]," entry in the sidebar, below ",["$","code",null,{"children":"Extensions"}],".\nThis screen lists your installed channel integrations and lets you open each integration's configuration view."]}]
87:["$","p",null,{"children":"A Telegram Channel extension can be installed as a user extension and configured from this screen.\nIt currently supports bot configuration, model selection through the Chatons model selector, status inspection, polling diagnostics, and test sends."}]
88:["$","p",null,{"children":"Channel extensions do not appear individually as their own sidebar entries."}]
89:["$","p",null,{"children":"Depending on the extension, a Channel integration can also mirror Chatons replies back to the external platform.\nFor example, the Telegram Channel extension can now create or reuse a Chatons global thread, apply the selected model to that thread, import inbound messages, and send Chatons replies back to Telegram.\nConnection, authentication, and sync status are extension-specific and usually exposed in the extension's own screen."}]
8a:["$","h2",null,{"id":"111-memory-extension","children":"11.1 Memory extension"}]
8b:["$","p",null,{"children":["Chatons now includes a built-in ",["$","code",null,{"children":"Memory"}]," extension."]}]
8c:["$","p",null,{"children":"What it does:"}]
8d:["$","ul",null,{"children":["\n",["$","li",null,{"children":"stores memories internally in Chatons local SQLite database"}],"\n",["$","li",null,{"children":["supports two memory scopes:","\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":[["$","code",null,{"children":"global"}],": personal facts, preferences, and long-lived user context"]}],"\n",["$","li",null,{"children":[["$","code",null,{"children":"project"}],": project-specific context, decisions, conventions, and useful facts"]}],"\n"]}],"\n"]}],"\n",["$","li",null,{"children":"exposes internal tools so the model can store, retrieve, update, and delete memories during normal conversations"}],"\n",["$","li",null,{"children":"includes a lightweight local semantic search engine embedded directly in Chatons, so no external embedding service is required"}],"\n"]}]
8e:["$","p",null,{"children":"Practical use cases:"}]
8f:["$","ul",null,{"children":["\n",["$","li",null,{"children":"remember user language/tone preferences globally"}],"\n",["$","li",null,{"children":"remember personal profile/context that helps personalize replies"}],"\n",["$","li",null,{"children":"remember project conventions, architecture decisions, or recurring instructions per project"}],"\n"]}]
90:["$","p",null,{"children":"Current note:"}]
91:["$","ul",null,{"children":["\n",["$","li",null,{"children":"the current local semantic search is intentionally lightweight and fully offline; it is designed to be small and functional rather than state-of-the-art"}],"\n"]}]
92:["$","h2",null,{"id":"12-settings-user-view","children":"12. Settings (User View)"}]
93:["$","p",null,{"children":"Settings sections currently available:"}]
94:["$","ul",null,{"children":["\n",["$","li",null,{"children":[["$","code",null,{"children":"General"}],": app-level Pi settings fields (theme etc.)"]}],"\n",["$","li",null,{"children":[["$","code",null,{"children":"Behaviors"}],": default behavior prompt automatically prepended"]}],"\n",["$","li",null,{"children":[["$","code",null,{"children":"Sidebar"}],": sidebar display options"]}],"\n",["$","li",null,{"children":[["$","code",null,{"children":"Sidebar"}],": also includes ",["$","code",null,{"children":"Allow anonymous crash/error details"}]," toggle (can be changed anytime)"]}],"\n",["$","li",null,{"children":[["$","code",null,{"children":"Language"}],": French / English"]}],"\n",["$","li",null,{"children":[["$","code",null,{"children":"Providers & Models"}],": provider config and model scoping"]}],"\n",["$","li",null,{"children":[["$","code",null,{"children":"Sessions"}],": open sessions folder"]}],"\n",["$","li",null,{"children":[["$","code",null,{"children":"Pi"}],": command output panel"]}],"\n",["$","li",null,{"children":[["$","code",null,{"children":"Diagnostics"}],": runtime checks and paths"]}],"\n"]}]
95:["$","h2",null,{"id":"121-crashlog-consent-card","children":"12.1 Crash/Log Consent Card"}]
96:["$","p",null,{"children":"After onboarding, Chatons can show a small bottom-right consent card asking whether you authorize anonymous crash/error details to improve Chatons."}]
97:["$","ul",null,{"children":["\n",["$","li",null,{"children":[["$","code",null,{"children":"Allow"}],": enables anonymous telemetry"]}],"\n",["$","li",null,{"children":[["$","code",null,{"children":"No thanks"}],": keeps telemetry disabled"]}],"\n"]}]
98:["$","h2",null,{"id":"13-macos-window-close-vs-quit","children":"13. macOS Window Close vs Quit"}]
99:["$","p",null,{"children":"On macOS, closing the Chatons window does not quit the app. The app keeps running in the background (menu bar/tray behavior)."}]
9a:["$","ul",null,{"children":["\n",["$","li",null,{"children":["Close window (",["$","code",null,{"children":"red dot"}],"): hides the window, app stays running"]}],"\n",["$","li",null,{"children":[["$","code",null,{"children":"Quitter"}]," (menu bar/tray) or ",["$","code",null,{"children":"Cmd + Q"}],": actually quits the app"]}],"\n"]}]
9b:["$","p",null,{"children":["This prompt is shown once per user choice, and the setting remains editable later in ",["$","code",null,{"children":"Settings > Sidebar"}],"."]}]
9c:["$","h2",null,{"id":"13-updates-and-changelog","children":"13. Updates and Changelog"}]
9d:["$","p",null,{"children":"Outside development mode:"}]
9e:["$","ul",null,{"children":["\n",["$","li",null,{"children":"update availability is shown in sidebar"}],"\n",["$","li",null,{"children":"download progress is displayed"}],"\n",["$","li",null,{"children":"changelog card appears for unseen version"}],"\n",["$","li",null,{"children":"if local changelog files are unavailable (or Electron bridge is unavailable), a built-in fallback changelog is shown"}],"\n",["$","li",null,{"children":"if no downloaded installer exists yet, update apply shows an actionable message instead of crashing"}],"\n"]}]
9f:["$","h2",null,{"id":"14-notifications","children":"14. Notifications"}]
a0:["$","p",null,{"children":"If the app window is not focused, Chatons can show a desktop notification when a conversation action completes."}]
a1:["$","h2",null,{"id":"15-current-product-notes","children":"15. Current Product Notes"}]
a2:["$","p",null,{"children":"Important practical notes for users today:"}]
a3:["$","ul",null,{"children":["\n",["$","li",null,{"children":"Some advanced worktree actions are still evolving and may show partial/limited behavior depending on environment."}],"\n",["$","li",null,{"children":"Extensions in the catalog can require restart and/or extra setup to become fully usable."}],"\n",["$","li",null,{"children":["Model/skills/settings Pi commands use Chatons internal Pi runtime and config directory under Chatons data. They do not require a user-global ",["$","code",null,{"children":"~/.pi"}]," Node setup."]}],"\n",["$","li",null,{"children":["Provider model lists are refreshed from the internal Pi ",["$","code",null,{"children":"--list-models"}]," command and synced into Chatons ",["$","code",null,{"children":"models.json"}]," when model sync runs."]}],"\n",["$","li",null,{"children":["On API authorization failures (for example ",["$","code",null,{"children":"401"}],"), Chatons logs a safe auth diagnostic trail (provider + masked key fingerprint) in runtime error details to help troubleshooting without exposing raw API keys."]}],"\n",["$","li",null,{"children":["The log console now includes Pi runtime events (",["$","code",null,{"children":"source = pi"}],") such as runtime status changes and runtime errors, in addition to Electron/frontend logs."]}],"\n",["$","li",null,{"children":["When a message send fails (for example model request returning ",["$","code",null,{"children":"401"}],"), Chatons now shows an in-app notice in the composer area so the failure is visible immediately; auth failures explicitly ask you to verify provider API keys."]}],"\n"]}]
a4:["$","p",null,{"children":"For technical details and extension authoring, use the developer guide."}]
