# Fichier d'exemple pour les variables d'environnement
# Copiez ce fichier en .env et remplissez avec vos informations

# Obligatoire pour la signature
APPLE_TEAM_ID="ABCDE12345"  # Votre Team ID Apple
APPLE_SIGNING_IDENTITY="Developer ID Application: Votre Nom (ABCDE12345)"  # Nom exact du certificat

# Obligatoire pour la notarization en build prod (méthode Apple ID)
# APPLE_ID="votre@email.com"  # Votre Apple ID
# APPLE_APP_SPECIFIC_PASSWORD="xxxx-xxxx-xxxx-xxxx"  # Mot de passe spécifique à l'application

# Optionnel si vous utilisez un certificat fichier (.p12)
# CSC_LINK="chemin/vers/votre/certificat.p12"
# CSC_KEY_PASSWORD="mot-de-passe-du-certificat"

# Optional telemetry override (Sentry)
# The app includes a default Sentry DSN; set this only to override it.
# SENTRY_DSN="https://<key>@o<org>.ingest.sentry.io/<project>"

# Note: Ne commitez jamais ce fichier avec vos vraies informations!
# Ajoutez .env à votre .gitignore
